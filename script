function getYTId(url){const m=url.match(/(?:youtu\.be\/|v=|\/embed\/)([A-Za-z0-9_-]{11})/);return m?m[1]:null}
function loadYT(){
  const url=document.getElementById('yt-url').value.trim();const id=getYTId(url);
  const wrap=document.getElementById('yt-wrap');const ph=document.getElementById('yt-ph');
  if(!id){ph.textContent='> ERROR: INVALID YOUTUBE URL_';return}
  wrap.innerHTML='';const iframe=document.createElement('iframe');iframe.src=`https://www.youtube.com/embed/${id}?rel=0`;iframe.allow='autoplay; encrypted-media';iframe.allowFullscreen=true;
  wrap.appendChild(iframe);wrap.classList.add('loaded');ph.style.display='none';
}
function clearYT(){
  const wrap=document.getElementById('yt-wrap');wrap.innerHTML='';wrap.classList.remove('loaded');
  document.getElementById('yt-ph').style.display='';document.getElementById('yt-ph').textContent='> NO TRACK LOADED_';document.getElementById('yt-url').value='';
}
document.getElementById('yt-url').addEventListener('keydown',e=>{if(e.key==='Enter')loadYT()});

