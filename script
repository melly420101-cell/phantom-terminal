function setupGif(inputId,imgId,hintId){
  document.getElementById(inputId).addEventListener('change',function(e){
    const file=e.target.files[0];if(!file)return;
    const reader=new FileReader();
    reader.onload=ev=>{const img=document.getElementById(imgId);img.src=ev.target.result;img.style.display='block';const h=document.getElementById(hintId);if(h)h.style.display='none'};
    reader.readAsDataURL(file);
  });
}
