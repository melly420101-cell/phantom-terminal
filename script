function setVar(k,v){document.documentElement.style.setProperty(k,v)}
function parseHex(hex){return[parseInt(hex.slice(1,3),16),parseInt(hex.slice(3,5),16),parseInt(hex.slice(5,7),16)]}
function darken(hex,a){if(!hex.startsWith('#'))return hex;const[r,g,b]=parseHex(hex);return`rgb(${Math.round(r*(1-a))},${Math.round(g*(1-a))},${Math.round(b*(1-a))})`}
function setGlow(hex){setVar('--glow',hex);setVar('--text',hex);setVar('--text-body',hex);setVar('--glow-dim',darken(hex,.35));setVar('--text-dim',darken(hex,.35));setVar('--glow-faint',darken(hex,.75));setVar('--glow-trace',darken(hex,.9));setVar('--text-faint',darken(hex,.65));renderWheel&&renderWheel()}
function setDanger(hex){setVar('--danger',hex);setVar('--danger-dim',darken(hex,.5))}
