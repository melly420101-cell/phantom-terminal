<script>
/* ══════════════════════════════════════
   WHEEL ENGINE — full Plutchik + dyads
   + Power Flower + theme-reactive colors
══════════════════════════════════════ */

/*
  Layout (clockwise from top, matching classic Plutchik):
  0  JOY          (top)
  1  TRUST
  2  FEAR
  3  SURPRISE
  4  SADNESS      (bottom)
  5  DISGUST
  6  ANGER
  7  ANTICIPATION

  Dyads sit between petals at petal_mid + 22.5 deg:
  JOY+TRUST      = LOVE
  TRUST+FEAR     = SUBMISSION
  FEAR+SURPRISE  = AWE
  SURPRISE+SAD   = DISAPPROVAL
  SAD+DISGUST    = REMORSE
  DISGUST+ANGER  = CONTEMPT
  ANGER+ANTICI   = AGGRESSIVENESS
  ANTICI+JOY     = OPTIMISM
*/

/* hue values match real Plutchik wheel pigments */
const EW=[
  {id:'joy',        label:'JOY',          r1:'SERENITY',   r2:'JOY',          r3:'ECSTASY',    hue:55,  sat:98},
  {id:'trust',      label:'TRUST',        r1:'ACCEPTANCE', r2:'TRUST',        r3:'ADMIRATION', hue:105, sat:65},
  {id:'fear',       label:'FEAR',         r1:'APPREHENSION',r2:'FEAR',        r3:'TERROR',     hue:148, sat:60},
  {id:'surprise',   label:'SURPRISE',     r1:'DISTRACTION',r2:'SURPRISE',     r3:'AMAZEMENT',  hue:188, sat:70},
  {id:'sadness',    label:'SADNESS',      r1:'PENSIVENESS',r2:'SADNESS',      r3:'GRIEF',      hue:222, sat:72},
  {id:'disgust',    label:'DISGUST',      r1:'BOREDOM',    r2:'DISGUST',      r3:'LOATHING',   hue:272, sat:58},
  {id:'anger',      label:'ANGER',        r1:'ANNOYANCE',  r2:'ANGER',        r3:'RAGE',       hue:8,   sat:92},
  {id:'anticipation',label:'ANTICIPATION',r1:'INTEREST',   r2:'ANTICIPATION', r3:'VIGILANCE',  hue:36,  sat:96},
];

/* Dyads: between petal[a] and petal[b], label, hue = avg of both */
const DYADS=[
  {a:0,b:1, label:'LOVE',           r1:'FONDNESS',    r2:'LOVE',          r3:'DEVOTION',    hue:80,  sat:80},
  {a:1,b:2, label:'SUBMISSION',     r1:'COMPLIANCE',  r2:'SUBMISSION',    r3:'SURRENDER',   hue:128, sat:55},
  {a:2,b:3, label:'AWE',            r1:'WONDER',      r2:'AWE',           r3:'REVERENCE',   hue:168, sat:55},
  {a:3,b:4, label:'DISAPPROVAL',    r1:'DOUBT',       r2:'DISAPPROVAL',   r3:'REJECTION',   hue:205, sat:65},
  {a:4,b:5, label:'REMORSE',        r1:'REGRET',      r2:'REMORSE',       r3:'GUILT',       hue:247, sat:60},
  {a:5,b:6, label:'CONTEMPT',       r1:'DISDAIN',     r2:'CONTEMPT',      r3:'SCORN',       hue:300, sat:50},
  {a:6,b:7, label:'AGGRESSIVENESS', r1:'BOLDNESS',    r2:'AGGRESSIVENESS',r3:'HOSTILITY',   hue:22,  sat:88},
  {a:7,b:0, label:'OPTIMISM',       r1:'HOPE',        r2:'OPTIMISM',      r3:'EUPHORIA',    hue:46,  sat:96},
];

const PW=[
  {id:'offence',    label:'OFFENCE',     r1:'MINOR',     r2:'MODERATE',   r3:'LETHAL',     hue:8,   sat:90},
  {id:'defence',    label:'DEFENCE',     r1:'PASSIVE',   r2:'ACTIVE',     r3:'FORTRESS',   hue:200, sat:68},
  {id:'control',    label:'CONTROL',     r1:'NUDGE',     r2:'INFLUENCE',  r3:'DOMINATE',   hue:272, sat:62},
  {id:'speed',      label:'SPEED',       r1:'FAST',      r2:'BLUR',       r3:'INSTANT',    hue:50,  sat:95},
  {id:'perception', label:'PERCEPTION',  r1:'KEEN',      r2:'ACUTE',      r3:'OMNISCIENT', hue:170, sat:58},
  {id:'endurance',  label:'ENDURANCE',   r1:'RESILIENT', r2:'TOUGH',      r3:'IMMORTAL',   hue:118, sat:62},
  {id:'utility',    label:'UTILITY',     r1:'MINOR',     r2:'VERSATILE',  r3:'ABSOLUTE',   hue:34,  sat:78},
  {id:'corruption', label:'CORRUPTION',  r1:'TAINTED',   r2:'WARPED',     r3:'CONSUMED',   hue:300, sat:55},
];

/* Power dyads */
const PDYADS=[
  {a:0,b:1, label:'SIEGE',      r1:'PRESSURE',   r2:'SIEGE',       r3:'DEVASTATION', hue:20,  sat:75},
  {a:1,b:2, label:'SHIELD',     r1:'GUARD',      r2:'SHIELD',      r3:'BULWARK',     hue:236, sat:62},
  {a:2,b:3, label:'BLINK',      r1:'DASH',       r2:'BLINK',       r3:'PHASE',       hue:160, sat:70},
  {a:3,b:4, label:'REFLEX',     r1:'INSTINCT',   r2:'REFLEX',      r3:'PRECOGNITION',hue:110, sat:76},
  {a:4,b:5, label:'RESILIENCE', r1:'RECOVERY',   r2:'RESILIENCE',  r3:'INVINCIBLE',  hue:144, sat:60},
  {a:5,b:6, label:'FORTIFY',    r1:'REINFORCE',  r2:'FORTIFY',     r3:'IMPENETRABLE',hue:76,  sat:68},
  {a:6,b:7, label:'ENTROPY',    r1:'DECAY',      r2:'ENTROPY',     r3:'ANNIHILATION',hue:320, sat:60},
  {a:7,b:0, label:'BLITZ',      r1:'SURGE',      r2:'BLITZ',       r3:'ONSLAUGHT',   hue:22,  sat:90},
];

let currentMode='emotion'; /* 'emotion' | 'power' | 'dyad' */
let emotionVals =[5,5,5,5,5,5,5,5];
let powerVals   =[5,5,5,5,5,5,5,5];
let dyadEmoVals =[5,5,5,5,5,5,5,5]; /* intensity for emotion dyad wheel */
let dyadPowVals =[5,5,5,5,5,5,5,5]; /* intensity for power dyad wheel */
/* dyad active arrays (shown on parent wheels) — all on by default */
let emotionDyads=[1,1,1,1,1,1,1,1];
let powerDyads  =[1,1,1,1,1,1,1,1];

function getVals(){
  if(currentMode==='emotion') return emotionVals;
  if(currentMode==='power')   return powerVals;
  if(currentMode==='dyad-e')  return dyadEmoVals;
  return dyadPowVals;
}
function getData(){
  if(currentMode==='emotion') return EW;
  if(currentMode==='power')   return PW;
  if(currentMode==='dyad-e')  return DYADS;
  return PDYADS;
}
function getDyads(){
  /* only emotion/power modes show dyad overlays on the wheel */
  if(currentMode==='emotion') return DYADS;
  if(currentMode==='power')   return PDYADS;
  return []; /* dyad wheel has no further sub-dyads */
}
function getDyadActive(){
  return currentMode==='emotion'?emotionDyads:powerDyads;
}
function isDyadWheel(){return currentMode==='dyad-e'||currentMode==='dyad-p';}

/* ── Math helpers ── */
function pxy(deg,r){const a=(deg-90)*Math.PI/180;return[r*Math.cos(a),r*Math.sin(a)]}
function f(n){return n.toFixed(2)}

function arc(r1,r2,aStart,aEnd,gap=0.9){
  const a=aStart+gap, b=aEnd-gap;
  const lg=(b-a>=180)?1:0;
  const[x1,y1]=pxy(a,r1);const[x2,y2]=pxy(b,r1);
  const[x3,y3]=pxy(b,r2);const[x4,y4]=pxy(a,r2);
  return`M${f(x1)},${f(y1)} A${r1},${r1} 0 ${lg},1 ${f(x2)},${f(y2)} L${f(x3)},${f(y3)} A${r2},${r2} 0 ${lg},0 ${f(x4)},${f(y4)} Z`;
}

/* ── Read a CSS variable from :root ── */
function cssVar(name){
  return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
}

/* ── Convert hsl+theme to a usable color.
   We blend between the theme's dark background and the pure hue color
   so ALL presets look correct. ── */
function wheelFill(hue,sat,lightness,alpha=1){
  /* Pure hsl — the wheel always uses real pigment colors regardless of theme,
     but we darken/lighten the background rings using the theme glow color as tint */
  if(alpha<1) return`hsla(${hue},${sat}%,${lightness}%,${alpha})`;
  return`hsl(${hue},${sat}%,${lightness}%)`;
}

/* stroke color uses theme --border-hi tinted with the petal hue */
function wheelStroke(hue,sat,l){
  return`hsl(${hue},${Math.round(sat*0.8)}%,${l}%)`;
}

/* ring structure lines use theme glow color */
function ringLine(){
  const g=cssVar('--glow')||'rgba(0,255,60,1)';
  /* convert to rgba with low opacity */
  if(g.startsWith('#')){
    const r=parseInt(g.slice(1,3),16);const gg=parseInt(g.slice(3,5),16);const b=parseInt(g.slice(5,7),16);
    return`rgba(${r},${gg},${b},0.09)`;
  }
  return g.replace('rgb(','rgba(').replace(')',',0.09)');
}

function renderWheel(){
  const svg=document.getElementById('wheel-svg');
  const data=getData();const dyads=getDyads();const vals=getVals();
  const n=data.length;const slice=360/n; /* 45 deg per petal */

  /* Ring radii */
  const R0=12;   /* core */
  const R1=32;   /* ring1 (mild) outer */
  const R2=58;   /* ring2 (moderate) outer */
  const R3=84;   /* ring3 (intense) outer — fixed, opacity/brightness varies */
  const RDYAD=96;/* dyad label ring */
  const RLABEL=108;/* main label ring */

  const rl=ringLine();
  let html='';

  /* ── Structure circles ── */
  [R1,R2,R3].forEach(r=>{ html+=`<circle cx="0" cy="0" r="${r}" fill="none" stroke="${rl}" stroke-width="0.5"/>`; });

  /* ── Spoke lines (between petals) ── */
  for(let i=0;i<n;i++){
    const [sx,sy]=pxy(i*slice,R0+1);const[ex,ey]=pxy(i*slice,R3+1);
    html+=`<line x1="${f(sx)}" y1="${f(sy)}" x2="${f(ex)}" y2="${f(ey)}" stroke="${rl}" stroke-width="0.5"/>`;
  }

  /* ── Petal segments ── */
  data.forEach((d,i)=>{
    const aS=i*slice, aE=(i+1)*slice;
    const v=vals[i];

    /* Ring 1 — always shown, mild intensity */
    const l1base=v===0?6:9+v*0.9;
    html+=`<path d="${arc(R0,R1,aS,aE)}" fill="${wheelFill(d.hue,Math.round(d.sat*0.55),l1base)}" stroke="${wheelStroke(d.hue,d.sat,l1base+14)}" stroke-width="0.5"/>`;

    /* Ring 2 — moderate, grows in brightness with val */
    const l2base=v===0?4:8+v*1.8;
    const a2=v===0?0.12:0.35+v*0.065;
    html+=`<path d="${arc(R1,R2,aS,aE)}" fill="${wheelFill(d.hue,d.sat,l2base,a2)}" stroke="${wheelStroke(d.hue,d.sat,l2base+14)}" stroke-width="0.5"/>`;

    /* Ring 3 — intense, brightness and glow scale with val */
    const l3base=v===0?3:6+v*2.8;
    const a3=v===0?0.06:0.15+v*0.085;
    const glowStr=v>=8?`filter:drop-shadow(0 0 2.5px hsl(${d.hue},${d.sat}%,65%))`:'';
    html+=`<path d="${arc(R2,R3,aS,aE)}" fill="${wheelFill(d.hue,d.sat,l3base,a3)}" stroke="${wheelStroke(d.hue,d.sat,l3base+16)}" stroke-width="${v>=8?0.8:0.4}" style="${glowStr}"/>`;

    /* ── Ring sub-labels — tangential text inside each ring ── */
    const mid=aS+slice/2;
    /*
      TANGENTIAL text (follows the arc curvature):
      A horizontal SVG text at point pxy(mid, r) rotated by `mid` degrees
      will have its baseline pointing in the arc-tangent direction.
      Bottom-half petals (90 < mid < 270) need +180 to avoid upside-down text.
    */
    const m360=((mid%360)+360)%360;
    const flip=m360>90&&m360<270;
    const trot=mid+(flip?180:0);

    const ringText=(text,r,hue,sat,lightBase,opacity,fsize)=>{
      const[tx,ty]=pxy(mid,r);
      const fc=`hsl(${hue},${Math.round(sat*0.7)}%,${lightBase+22}%)`;
      return`<text x="${f(tx)}" y="${f(ty)}" text-anchor="middle" dominant-baseline="middle" font-family="'Share Tech Mono',monospace" font-size="${fsize}" fill="${fc}" opacity="${opacity.toFixed(2)}" transform="rotate(${f(trot)},${f(tx)},${f(ty)})">${text}</text>`;
    };

    html+=ringText(d.r1,(R0+R1)/2, d.hue,d.sat, v===0?5:l1base,  v===0?0.25:0.65, 3.4);
    html+=ringText(d.r2,(R1+R2)/2, d.hue,d.sat, v===0?3:l2base,  v===0?0.14:0.70, 3.4);
    html+=ringText(d.r3,(R2+R3)/2, d.hue,d.sat, v===0?2:l3base,  v===0?0.07:Math.min(0.78,0.18+v*0.09), 3.4);

    /* ── Outer main label — RADIAL outward ── */
    const[lx,ly]=pxy(mid,RLABEL);
    /*
      RADIAL text (points away from centre like a spoke):
      Rotate text by `mid` degrees so it aligns along the spoke.
      This makes text read outward on the top half.
      Bottom half: add 180 so reader doesn't see it upside-down.
      We use text-anchor="middle" so the text centres on the spoke.
    */
    const lrot=mid+(flip?180:0);
    const lc=`hsl(${d.hue},${Math.round(d.sat*0.8)}%,${52+v*2.5}%)`;
    html+=`<text x="${f(lx)}" y="${f(ly)}" text-anchor="middle" dominant-baseline="middle" font-family="'Share Tech Mono',monospace" font-size="5.2" fill="${lc}" font-weight="bold" transform="rotate(${f(lrot)},${f(lx)},${f(ly)})">${d.label}</text>`;
  });

  /* ── Dyad labels — on the spoke between petals, toggleable ── */
  const dyadActive=getDyadActive();
  dyads.forEach((dy,i)=>{
    if(!dyadActive[i]) return; /* hidden if toggled off */
    const spokeAngle=((dy.a+1)*slice)%360;
    const[dx,dy2]=pxy(spokeAngle,RDYAD);
    const sm=((spokeAngle%360)+360)%360;
    const dflip=sm>90&&sm<270;
    /*
      Dyad text is TANGENTIAL on the spoke (same formula as ring text).
      Rotate by spokeAngle to align along the spoke tangent.
      Flip bottom half.
    */
    const drot=spokeAngle+(dflip?180:0);
    const dc=`hsl(${dy.hue},${Math.round(dy.sat*0.65)}%,38%)`;
    html+=`<text x="${f(dx)}" y="${f(dy2)}" text-anchor="middle" dominant-baseline="middle" font-family="'Share Tech Mono',monospace" font-size="3.6" fill="${dc}" transform="rotate(${f(drot)},${f(dx)},${f(dy2)})" opacity="0.88" font-style="italic">${dy.label}</text>`;
  });

  /* ── Centre core ── */
  const glowDim=cssVar('--glow-dim')||'#00a828';
  const bgCol=cssVar('--bg')||'#000300';
  const faintCol=cssVar('--text-faint')||'#005518';
  html+=`<circle cx="0" cy="0" r="${R0}" fill="${bgCol}" stroke="${glowDim}" stroke-width="0.8"/>`;
  html+=`<text x="0" y="-2.2" text-anchor="middle" dominant-baseline="middle" font-family="'VT323',monospace" font-size="6.5" fill="${glowDim}" letter-spacing="0.5">${currentMode==='emotion'?'PSYCHE':'POWER'}</text>`;
  html+=`<text x="0" y="4.5" text-anchor="middle" dominant-baseline="middle" font-family="'VT323',monospace" font-size="4" fill="${faintCol}">INDEX</text>`;

  svg.innerHTML=html;
}

function buildSliders(){
  const data=getData();const vals=getVals();
  const wrap=document.getElementById('wheel-controls');wrap.innerHTML='';
  const isParent=currentMode==='emotion'||currentMode==='power';

  /* ── Sliders ── */
  const grid=document.createElement('div');
  grid.style.cssText='display:grid;grid-template-columns:1fr;gap:10px';
  if(window.innerWidth>=520) grid.style.gridTemplateColumns='1fr 1fr';

  data.forEach((d,i)=>{
    const row=document.createElement('div');row.className='emo-row';
    const v=vals[i];
    const hue=d.hue;const sat=d.sat;
    const lt=v<=3?(d.r1||d.label):v<=7?(d.r2||d.label):(d.r3||d.label);
    const lbl=document.createElement('div');lbl.className='emo-label';
    lbl.innerHTML=`<span style="color:hsl(${hue},${sat}%,58%);letter-spacing:1px;font-size:11px">${d.label}</span><span style="font-size:9px;color:hsl(${hue},${sat}%,32%);letter-spacing:0.5px;display:block;margin-top:2px">${v>0?lt:'—'}</span>`;
    const sl=document.createElement('input');sl.type='range';sl.min='0';sl.max='10';sl.step='1';sl.value=v;sl.className='emo-slider';
    sl.style.accentColor=`hsl(${hue},${sat}%,55%)`;
    const num=document.createElement('div');num.className='emo-val';num.textContent=v;
    sl.addEventListener('input',()=>{
      const nv=parseInt(sl.value);num.textContent=nv;
      if(currentMode==='emotion')emotionVals[i]=nv;
      else if(currentMode==='power')powerVals[i]=nv;
      else if(currentMode==='dyad-e')dyadEmoVals[i]=nv;
      else dyadPowVals[i]=nv;
      const nt=nv<=3?(d.r1||d.label):nv<=7?(d.r2||d.label):(d.r3||d.label);
      lbl.innerHTML=`<span style="color:hsl(${hue},${sat}%,58%);letter-spacing:1px;font-size:11px">${d.label}</span><span style="font-size:9px;color:hsl(${hue},${sat}%,32%);letter-spacing:0.5px;display:block;margin-top:2px">${nv>0?nt:'—'}</span>`;
      renderWheel();
    });
    row.append(lbl,sl,num);grid.appendChild(row);
  });
  wrap.appendChild(grid);

  /* ── Dyad toggles — only on parent wheels ── */
  if(!isParent)return;
  const dyads=getDyads();const dyadActive=getDyadActive();

  const dSep=document.createElement('div');
  dSep.style.cssText='height:1px;background:var(--border-hi);opacity:0.4;margin:8px 0 6px';
  wrap.appendChild(dSep);
  const dTitle=document.createElement('div');
  dTitle.style.cssText='font-size:10px;letter-spacing:3px;color:var(--text-faint);text-transform:uppercase;margin-bottom:8px';
  dTitle.textContent='> DYADS // TAP TO TOGGLE_';
  wrap.appendChild(dTitle);
  const dGrid=document.createElement('div');
  dGrid.style.cssText='display:grid;grid-template-columns:1fr 1fr;gap:6px';
  if(window.innerWidth>=520) dGrid.style.gridTemplateColumns='repeat(4,1fr)';
  dyads.forEach((dy,i)=>{
    const btn=document.createElement('button');
    const on=dyadActive[i]===1;
    btn.style.cssText=`background:${on?`hsl(${dy.hue},${dy.sat}%,12%)`:'transparent'};border:1px solid hsl(${dy.hue},${Math.round(dy.sat*0.5)}%,${on?28:16}%);color:hsl(${dy.hue},${dy.sat}%,${on?55:28}%);font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:1px;padding:8px 4px;cursor:pointer;text-align:center;text-transform:uppercase;-webkit-appearance:none;border-radius:0;transition:all .15s;line-height:1.5`;
    btn.innerHTML=`<span style="display:block;font-size:7px;opacity:0.55;margin-bottom:2px">${data[dy.a].label.slice(0,3)}+${data[dy.b].label.slice(0,3)}</span>${dy.label}`;
    btn.addEventListener('click',()=>{
      const newOn=dyadActive[i]===0?1:0;
      if(currentMode==='emotion')emotionDyads[i]=newOn;else powerDyads[i]=newOn;
      btn.style.background=newOn?`hsl(${dy.hue},${dy.sat}%,12%)`:'transparent';
      btn.style.borderColor=`hsl(${dy.hue},${Math.round(dy.sat*0.5)}%,${newOn?28:16}%)`;
      btn.style.color=`hsl(${dy.hue},${dy.sat}%,${newOn?55:28}%)`;
      renderWheel();
    });
    dGrid.appendChild(btn);
  });
  wrap.appendChild(dGrid);
}

