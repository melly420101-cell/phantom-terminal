/* SAVE SYSTEM */
function collectFields(){const d={};document.querySelectorAll('[data-key]').forEach(el=>{d[el.dataset.key]=el.value});return d}
function restoreFields(data){if(!data)return;document.querySelectorAll('[data-key]').forEach(el=>{if(data[el.dataset.key]!==undefined)el.value=data[el.dataset.key]})}

function buildState(){
  return{fields:collectFields(),tier:currentTier,emotionVals:emotionVals.slice(),powerVals:powerVals.slice(),dyadEmoVals:dyadEmoVals.slice(),dyadPowVals:dyadPowVals.slice(),emotionDyads:emotionDyads.slice(),powerDyads:powerDyads.slice(),factionVals:factionVals.slice(),wheelMode:currentMode,ytUrl:document.getElementById('yt-url').value};
}

function restoreState(state){
  if(!state)return;
  restoreFields(state.fields);
  if(state.tier)setTier(state.tier);
  if(state.emotionVals)emotionVals=state.emotionVals;
  if(state.powerVals)powerVals=state.powerVals;
  if(state.dyadEmoVals)dyadEmoVals=state.dyadEmoVals;
  if(state.dyadPowVals)dyadPowVals=state.dyadPowVals;
  if(state.emotionDyads)emotionDyads=state.emotionDyads;
  if(state.powerDyads)powerDyads=state.powerDyads;
  if(state.factionVals){
    state.factionVals.forEach((v,fi)=>{
      factionVals[fi]=v;
      const rows=document.querySelectorAll('.faction-row');
      if(rows[fi]){
        rows[fi].querySelectorAll('.pip').forEach((p,idx)=>p.classList.toggle('on',idx<v));
        const nm=rows[fi].querySelector('.faction-val');if(nm)nm.textContent=v;
      }
    });
  }
  if(state.wheelMode)currentMode=state.wheelMode;
  if(state.ytUrl)document.getElementById('yt-url').value=state.ytUrl;
  ['emotion','power','dyad-e','dyad-p'].forEach(m=>{
    const el=document.getElementById('tab-'+m);
    if(el)el.classList.toggle('active',m===currentMode);
  });
  renderWheel();buildSliders();
}

function saveHTML(){
  const state=buildState();
  const imgs={};
  ['portrait-img','gif-img','eg1i','eg2i','eg3i'].forEach(id=>{
    const el=document.getElementById(id);
    if(el&&el.src&&el.src.startsWith('data:'))imgs[id]=el.src;
  });
  const stateData=JSON.stringify({state,imgs});
  const clone=document.documentElement.cloneNode(true);
  const old=clone.querySelector('#_ss');if(old)old.remove();
  const sc=clone.ownerDocument.createElement('script');
  sc.id='_ss';
  sc.textContent=`(function(){const _d=${stateData};window.addEventListener('DOMContentLoaded',function(){if(window._sr)return;window._sr=true;if(_d.state)restoreState(_d.state);if(_d.imgs){Object.entries(_d.imgs).forEach(([id,src])=>{const el=document.getElementById(id);if(el){el.src=src;el.style.display='block';const hmap={'portrait-img':'portrait-hint','gif-img':'gif-hint','eg1i':'eg1h','eg2i':'eg2h','eg3i':'eg3h'};const h=document.getElementById(hmap[id]);if(h)h.style.display='none'}});}});})();`;
  clone.querySelector('body').appendChild(sc);
  const html='<!DOCTYPE html>\n'+clone.outerHTML;
  const blob=new Blob([html],{type:'text/html'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);
  const nm=(collectFields().name||'character').replace(/[^a-z0-9]/gi,'_').toLowerCase();
  a.download=`INTV_${nm}_sheet.html`;a.click();URL.revokeObjectURL(a.href);
  showStatus('SAVED TO FILE_');
}

function copyLink(){
  const state=buildState();
  const json=JSON.stringify(state);
  const compressed=btoa(unescape(encodeURIComponent(json)));
  const url=window.location.href.split('?')[0]+'?d='+compressed;
  const fallback=()=>{const ta=document.createElement('textarea');ta.value=url;document.body.appendChild(ta);ta.select();document.execCommand('copy');document.body.removeChild(ta);showStatus('LINK COPIED_')};
  if(navigator.clipboard){navigator.clipboard.writeText(url).then(()=>showStatus('LINK COPIED_')).catch(fallback)}else{fallback()}
}

function loadFromURL(){
  const params=new URLSearchParams(window.location.search);const d=params.get('d');if(!d)return;
  try{const json=decodeURIComponent(escape(atob(d)));const state=JSON.parse(json);restoreState(state);showStatus('DATA LOADED FROM LINK_')}catch(e){console.warn('URL load failed:',e)}
}

function showStatus(msg){
  const el=document.getElementById('save-status');el.textContent='> '+msg;
  setTimeout(()=>{el.textContent=''},3200);
}

buildFactions();renderWheel();buildSliders();loadFromURL();
</script>

